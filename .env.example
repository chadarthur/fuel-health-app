# ─── Database (Neon PostgreSQL — free at neon.tech) ──────────────────────────
# After creating a Neon project, copy the "Connection string" from the dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Get from platform.openai.com/api-keys (for photo analysis / GPT-4o vision)
OPENAI_API_KEY=""

# Get from console.anthropic.com (for recipe generation & chat)
ANTHROPIC_API_KEY=""

# Which AI to use by default: "anthropic" or "openai"
AI_DEFAULT_PROVIDER="anthropic"

# ─── Recipe Search ────────────────────────────────────────────────────────────
# Get from spoonacular.com/food-api (free tier: 150 req/day)
SPOONACULAR_API_KEY=""

# ─── Whoop Integration ────────────────────────────────────────────────────────
# Register at https://developer.whoop.com to get Client ID and Secret
# Set WHOOP_MOCK_MODE="false" and fill in credentials to use real data
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""
# Must match exactly what you set in the WHOOP developer portal
# Local: http://localhost:3000/api/whoop/callback
# Production: https://yourdomain.com/api/whoop/callback
WHOOP_REDIRECT_URI="http://localhost:3000/api/whoop/callback"
WHOOP_MOCK_MODE="true"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-random-secret-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
